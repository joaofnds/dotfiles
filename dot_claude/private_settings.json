{
  "effortLevel": "high",
  "model": "opus[1m]",
  "switchModelsOnFlag": false,
  "agentPushNotifEnabled": true,
  "inputNeededNotifEnabled": true,
  "autoDreamEnabled": true,
  "autoMemoryEnabled": true,
  "remoteControlAtStartup": true,
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "tui": "fullscreen",
  "theme": "auto",

  "permissions": { "defaultMode": "bypassPermissions" },

  "skillOverrides": {
    "schedule": "user-invocable-only",
    "loop": "user-invocable-only",
    "keybindings-help": "user-invocable-only",
    "fewer-permission-prompts": "user-invocable-only",
    "deep-research": "name-only",
    "claude-api": "name-only"
  },

  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude/statusline-command.js"
  },

  "enabledPlugins": {},

  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_DISABLE_OFFICIAL_MARKETPLACE_AUTOINSTALL": "1",

    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_FEEDBACK_COMMAND": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1"
  },

  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/announce-rules-reminder.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/announce-rules-verify.py"
          }
        ]
      }
    ]
  }
}
